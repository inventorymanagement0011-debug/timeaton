# ================================================================
# TIM EATON — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ================================================================

# --- Stripe ---
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
# Get from https://dashboard.stripe.com/webhooks (for production)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# --- Session ---
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING

# --- Admin Panel ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# --- Site Config ---
PORT=3000
# Your production domain (for Stripe redirect URLs)
SITE_URL=http://localhost:3000

# --- Email (for order notifications — optional) ---
# Use Resend, SendGrid, or Nodemailer SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=yourpassword
# NOTIFY_EMAIL=timeatonart@gmail.com
